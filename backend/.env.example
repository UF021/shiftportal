# ── ShiftPortal Backend — Environment Variables ──────────────────────────────
# Copy this to .env for local development
# On Railway these are set via the Variables tab — Railway injects DATABASE_URL automatically

# Database (Railway provides this when you add a PostgreSQL plugin — do NOT set manually there)
DATABASE_URL=postgresql://user:password@localhost:5432/shiftportal

# JWT secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-STRING

# Token expiry in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Platform super-admin credentials (used by /api/superadmin/seed endpoint)
SUPERADMIN_EMAIL=admin@ikanfm.co.uk
SUPERADMIN_PASSWORD=CHANGE-THIS-TOO

# Stripe — leave blank until ready to charge customers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
APP_NAME=ShiftPortal
APP_URL=https://portal.ikanfm.co.uk

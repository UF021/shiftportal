# ── ShiftPortal Frontend — Environment Variables ─────────────────────────────
# For local dev: leave blank (Vite proxies /api → localhost:8000)
# For Vercel: set to your Railway backend URL

VITE_API_URL=https://YOUR-APP.railway.app/api

# Public-facing app URL (used for QR code generation — must match the domain staff will use)
VITE_APP_URL=https://portal.ikanfm.co.uk

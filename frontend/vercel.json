{
  "buildCommand":   "npm run build",
  "outputDirectory":"dist",
  "installCommand": "npm install",
  "framework":      "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://web-production-a4362f.up.railway.app/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "env": {
    "VITE_APP_URL": "https://portal.ikanfm.co.uk"
  }
}
